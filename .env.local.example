# .env.local.example - Example environment configuration
# Copy this to .env.local and fill in your actual values from your deployment platform

# REQUIRED: Admin password hash (configure in your deployment platform - Vercel, etc.)
ADMIN_PASSWORD_HASH=your_password_hash_from_deployment_platform

# REQUIRED: Secret for JWT token signing (configure in your deployment platform)
ADMIN_JWT_SECRET=your_jwt_secret_from_deployment_platform

# OPTIONAL: App URL (useful for some checks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OPTIONAL: Supabase configuration (if using Supabase instead of local JSON files)
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_KEY=your-supabase-service-key

# NOTE: This file should NEVER be committed to version control
# It is already in .gitignore
# All sensitive values should be configured in your deployment platform