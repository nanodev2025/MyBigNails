# .env.local.example - Example environment configuration
# Copy this to .env.local and fill in your actual values

# REQUIRED: Admin password hash (generate with: node scripts/generate-password-hash.js your-password)
# Example below is for password "admin123" - REPLACE WITH YOUR OWN!
ADMIN_PASSWORD_HASH=$2a$10$N9q8uLOickgxJLvUGMfBy.Mrkt5l5m8a3d1JZ8QJQJQJQJQJQJQJQ

# REQUIRED: Secret for JWT token signing (use a long random string, at least 32 characters)
ADMIN_JWT_SECRET=your-very-long-random-secret-here-at-least-32-characters-long

# OPTIONAL: App URL (useful for some checks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OPTIONAL: Supabase configuration (if using Supabase instead of local JSON files)
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_KEY=your-supabase-service-key

# NOTE: This file should NEVER be committed to version control
# It is already in .gitignore